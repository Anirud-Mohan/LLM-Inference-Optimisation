# -----------------------------------------------------------------------
# RunPod Pod deployment (used by locustfile.py, llm_as_eval.py)
# -----------------------------------------------------------------------
# Pod 1 proxy URL  e.g. https://<POD_ID>-8000.proxy.runpod.net
POD_1_URL=https://YOUR_POD_ID-8000.proxy.runpod.net

# Pod 2 proxy URL (leave blank for single-pod test)
POD_2_URL=https://YOUR_POD_ID-8000.proxy.runpod.net

# Model name served on the pod (custom_server.py)
MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# -----------------------------------------------------------------------
# Judge LLM credentials (used by llm_as_eval.py)
# -----------------------------------------------------------------------
JUDGE_API_KEY=your_judge_api_key
JUDGE_API_BASE=https://api.deepseek.com/v1
JUDGE_MODEL=deepseek-chat
